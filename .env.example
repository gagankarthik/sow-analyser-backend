# Copy to .env and fill in your values. Never commit .env.

# ── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Project ───────────────────────────────────────────────────────────────────
PROJECT_NAME=blue-iq-sow
STAGE=dev

# ── OpenAI (injected directly into Lambda env — no Secrets Manager needed) ───
OPENAI_API_KEY=sk-proj-...
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4.1-mini

# ── AWS Resources (auto-populated by Terraform; set manually for local dev) ───
DDB_TABLE_NAME=blue-iq-sow-dev-main
RAW_BUCKET=blue-iq-sow-dev-raw-<account-id>
PROCESSED_BUCKET=blue-iq-sow-dev-processed-<account-id>
OPENSEARCH_ENDPOINT=

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXTJS_ORIGIN=http://localhost:3000

# ── Feature flags ─────────────────────────────────────────────────────────────
ENABLE_NEPTUNE=false
ENABLE_OPENSEARCH=true
ENABLE_APPSYNC=true
